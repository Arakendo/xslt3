{
  "name": "@arakendo/weaver-xslt",
  "version": "0.0.1",
  "description": "Weaver is a TypeScript XSLT 3.0 engine",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arakendo/weaver-xslt.git"
  },
  "bugs": {
    "url": "https://github.com/Arakendo/weaver-xslt/issues"
  },
  "homepage": "https://github.com/Arakendo/weaver-xslt#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "weaver-xslt": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js"
    },
    "./workbench": {
      "types": "./dist/workbench.d.ts",
      "import": "./dist/workbench.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "devtools:fixture": "npx --yes vite@7.1.12 --config devtools-fixture/vite.config.ts --host 127.0.0.1 --port 4173",
    "build:workbench-site": "esbuild scripts/workbench-site/app.ts --bundle --platform=browser --format=esm --outfile=docs/assets/workbench/app.js && esbuild scripts/workbench-site/worker.ts --bundle --platform=browser --format=esm --outfile=docs/assets/workbench/worker.js",
    "test:packaging": "npm run build && npm pack --json --dry-run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run test/conformance",
    "benchmark:watch": "tsx scripts/benchmark-watch.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "xslt",
    "weaver",
    "weaver-xslt",
    "xpath",
    "xml",
    "typescript"
  ],
  "author": "Arakendo",
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.9.5",
    "chokidar": "^4.0.3",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.27.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
